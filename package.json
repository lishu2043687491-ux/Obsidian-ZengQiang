{
  "name": "feishu-doc-toolbar",
  "version": "1.14.28",
  "description": "Obsidian Enhanced Experience — unified toolbar, templates, and utilities",
  "repository": {
    "type": "git",
    "url": "https://github.com/lishu/feishu-doc-toolbar.git"
  },
  "author": "lishu",
  "license": "MIT",
  "scripts": {
    "sync:block-link-plus": "cp ../../_archived-superseded-by-feishu-embedded/block-link-plus/main.js src/modules/block-link-plus.bundle.js && node scripts/verify-blp-bundle-patches.mjs",
    "build": "node scripts/build.mjs",
    "build:oss": "OSS_RELEASE=1 node scripts/build.mjs",
    "audit:css": "node scripts/audit-css-lint.mjs",
    "audit:privacy": "node scripts/audit-privacy.mjs",
    "build:claudian-test": "esbuild tests/export-claudian-test.ts --bundle --platform=node --format=cjs --target=es2020 --outfile=tests/claudian-test-bundle.cjs",
    "build:auto-updater-test": "esbuild src/modules/managed-plugin-auto-updater.ts --bundle --platform=node --format=cjs --target=es2020 --external:obsidian --outfile=tests/managed-plugin-auto-updater-bundle.cjs",
    "build:goal-progress-test": "esbuild src/modules/goal-progress-sync.ts --bundle --platform=node --format=cjs --target=es2020 --define:__OSS_RELEASE__=false --outfile=tests/goal-progress-sync-bundle.cjs",
    "build:native-table-video-test": "esbuild src/modules/native-table-video-helpers.ts --bundle --platform=node --format=cjs --target=es2020 --outfile=tests/native-table-video-helpers-bundle.cjs",
    "build:video-timestamp-preview-test": "esbuild src/modules/video-timestamp-preview-helpers.ts --bundle --platform=node --format=cjs --target=es2020 --outfile=tests/video-timestamp-preview-helpers-bundle.cjs",
    "build:advanced-table-test": "esbuild src/modules/native-table-advanced-helpers.ts --bundle --platform=node --format=cjs --target=es2020 --outfile=tests/advanced-table-helpers-bundle.cjs",
    "test:iteration-guardrails": "node ./tests/iteration-guardrails.cjs",
    "test:native-table-selection-style": "node ./tests/native-table-selection-style.cjs",
    "test:native-table-regression": "npm run test:native-table-selection-style && node ./tests/native-table-markerless-regression.cjs",
    "test:advanced-tables-parity": "npm run build:advanced-table-test && node ./tests/advanced-tables-parity.cjs",
    "test:smoke": "npm run build && npm run build:claudian-test && npm run build:auto-updater-test && npm run build:goal-progress-test && npm run build:native-table-video-test && npm run build:video-timestamp-preview-test && npm run build:advanced-table-test && npm run test:iteration-guardrails && NODE_PATH=./test-support node ./tests/block-link-plus-host.cjs && NODE_PATH=./test-support node ./tests/smoke.js && NODE_PATH=./test-support node ./tests/claudian-cross-device-bridge.cjs && NODE_PATH=./test-support node ./tests/managed-plugin-auto-updater.cjs && NODE_PATH=./test-support node ./tests/managed-plugin-auto-updater-integration.cjs && node ./tests/goal-progress-sync.cjs && node ./tests/native-table-video-helpers.cjs && node ./tests/video-timestamp-preview-helpers.cjs && npm run test:native-table-regression && node ./tests/advanced-tables-parity.cjs && node ./tests/embedded-blp-boot.cjs && node ./tests/embedded-blp-obsidian-parity.cjs && node ./tests/embedded-blp-view-registry.cjs && node ./tests/embedded-blp-editor-isolation.cjs && node ./tests/embedded-blp-bundle-only.cjs",
    "community:check-releases": "node scripts/trigger-community-release-check.mjs",
    "community:login": "OBSIDIAN_COMMUNITY_HEADED=1 node scripts/trigger-community-release-check.mjs",
    "publish:oss": "bash scripts/publish-oss.sh",
    "package:oss": "npm run build:oss && node scripts/package-oss.mjs"
  },
  "dependencies": {
    "@tgrosinger/md-advanced-tables": "3.11.0",
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "esbuild": "^0.25.3",
    "playwright": "^1.52.0"
  }
}
